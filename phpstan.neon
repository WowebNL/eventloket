includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    treatPhpDocTypesAsCertain: false

    paths:
        - app/

    # Level 10 is the highest level
    level: 5

    reportUnmatchedIgnoredErrors: false

    ignoreErrors:
        # Filament Pages exposen $this->form via een trait (InteractsWithForms)
        # die PHPStan niet traceert. Pre-existing issue dat met de POC al bestond.
        -
            identifier: property.notFound
            path: app/Filament/Organiser/Pages/*
            message: '#Access to an undefined property [^:]+::\$form\.#'
        # Gegenereerde rule-klassen: triggers zijn 1-op-1 gecompileerde
        # JsonLogic-expressies op FormState::get() (mixed). PHPStan kan de
        # dynamische types niet bewijzen, waardoor sommige comparisons
        # 'always true/false' worden gemarkeerd. Dat is een false positive
        # inherent aan de codegen — we vertrouwen op OF's rule-semantiek.
        -
            identifier: identical.alwaysTrue
            path: app/EventForm/Rules/*
        -
            identifier: identical.alwaysFalse
            path: app/EventForm/Rules/*
        -
            identifier: notIdentical.alwaysTrue
            path: app/EventForm/Rules/*
        -
            identifier: notIdentical.alwaysFalse
            path: app/EventForm/Rules/*
        -
            identifier: booleanAnd.alwaysFalse
            path: app/EventForm/Rules/*
        -
            identifier: booleanAnd.alwaysTrue
            path: app/EventForm/Rules/*
        -
            identifier: booleanOr.alwaysFalse
            path: app/EventForm/Rules/*
        -
            identifier: booleanOr.alwaysTrue
            path: app/EventForm/Rules/*
        -
            identifier: ternary.alwaysTrue
            path: app/EventForm/Rules/*
        -
            identifier: ternary.alwaysFalse
            path: app/EventForm/Rules/*
        # Gegenereerde Schema/Steps: de visibility-closures combineren een
        # statisch-emit `true`/`false` met runtime `$get(...)`-checks; PHPStan
        # ziet dat als dead code maar het is intentional per-veld codegen.
        -
            identifier: booleanOr.leftAlwaysTrue
            path: app/EventForm/Schema/Steps/*
        -
            identifier: booleanOr.leftAlwaysFalse
            path: app/EventForm/Schema/Steps/*
        -
            identifier: booleanOr.rightAlwaysTrue
            path: app/EventForm/Schema/Steps/*
        -
            identifier: booleanOr.rightAlwaysFalse
            path: app/EventForm/Schema/Steps/*
